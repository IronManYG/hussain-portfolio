{
  "name": "hussain-portfolio",
  "version": "1.0.0",
  "description": "> Personal portfolio website for **Hussain Gaddal**, Senior Android Developer with 4+ years of experience building production-grade mobile applications.",
  "main": "main.js",
  "scripts": {
    "start": "npm-run-all --parallel watch:*",
    "build": "npm-run-all build:*",
    "build:css": "npx tailwindcss -i ./src/css/styles.css -o ./_site/styles.css --minify",
    "build:eleventy": "npx @11ty/eleventy",
    "watch:css": "npx tailwindcss -i ./src/css/styles.css -o ./_site/styles.css --watch",
    "watch:eleventy": "npx @11ty/eleventy --serve"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IronManYG/hussain-portfolio.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/IronManYG/hussain-portfolio/issues"
  },
  "homepage": "https://github.com/IronManYG/hussain-portfolio#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@tailwindcss/cli": "^4.2.2",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^3.4.19"
  }
}
