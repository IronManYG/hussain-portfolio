<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default("Hussain Gaddal | Senior Android Developer") }}</title>
    <meta name="description" content="{{ description | default('Hussain Gaddal — Senior Android Developer with 4+ years building scalable Kotlin & Jetpack Compose apps.') }}">
    <link rel="icon" type="image/svg+xml" href="{{ '/favicon.svg' | url }}">
    
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ title | default('Hussain Gaddal | Senior Android Developer') }}">
    <meta property="og:description" content="{{ description | default('Hussain Gaddal — Senior Android Developer with 4+ years building scalable Kotlin & Jetpack Compose apps.') }}">
    <meta property="og:url" content="https://ironmanyg.github.io/hussain-portfolio{{ page.url | url }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta property="og:image" content="https://ironmanyg.github.io/hussain-portfolio{{ '/assets/img/og-image.png' | url }}">
    
    <script>
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'light') { document.documentElement.classList.remove('dark'); }
        else { document.documentElement.classList.add('dark'); }
    </script>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <link rel="stylesheet" href="{{ '/styles.css' | url }}">
    <link rel="manifest" href="{{ '/manifest.json' | url }}">
    <meta name="theme-color" content="#0D1117">
</head>
<body class="bg-ide-bg text-ide-text-main antialiased selection:bg-kotlin-purple/30 selection:text-ide-text-strong">

    <!-- Navbar -->
    <nav class="fixed w-full z-50 top-0 border-b border-ide-border bg-ide-bg/80 backdrop-blur-md">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            {% if page.url == '/' %}
            <a href="{{ '/' | url }}" class="text-xl font-bold font-mono tracking-tighter hover:text-kotlin-purple transition-colors">
                <span class="text-kotlin-orange">&lt;</span>HG<span class="text-kotlin-orange">/&gt;</span>
            </a>
            <div class="space-x-8 text-sm font-medium text-ide-text-muted hidden md:flex">
                <a href="#about" class="nav-link hover:text-ide-text-strong transition-colors">About</a>
                <a href="{{ '/about/' | url }}" class="nav-link hover:text-ide-text-strong transition-colors">Experience / CV</a>
                <a href="#projects" class="nav-link hover:text-ide-text-strong transition-colors">Projects</a>
                <a href="#expertise" class="nav-link hover:text-ide-text-strong transition-colors">Expertise</a>
                <a href="#contact" class="nav-link hover:text-ide-text-strong transition-colors">Contact</a>
            </div>
            {% else %}
            <a href="{{ '/' | url }}" class="flex items-center text-ide-text-muted hover:text-ide-text-strong transition-colors">
                <i class="ph ph-arrow-left mr-2"></i> Back to Portfolio
            </a>
            {% endif %}
            
            <div class="flex items-center space-x-4 flex-row-reverse space-x-reverse md:flex-row md:space-x-4 text-ide-text-muted">
                {% if page.url == '/' %}
                <button id="mobile-menu-btn" class="text-2xl hover:text-ide-text-strong transition-colors p-1 md:hidden" aria-label="Open Navigation Menu">
                    <i class="ph ph-list"></i>
                </button>
                {% endif %}
                {% if repoUrl %}
                <a href="{{ repoUrl }}" target="_blank" rel="noopener noreferrer" class="btn-primary text-sm px-4 py-2 flex items-center">
                    <i class="ph ph-github-logo mr-2 text-lg"></i> View Source
                </a>
                {% endif %}
                <button id="theme-toggle" class="text-xl hover:text-ide-text-strong transition-colors p-1" aria-label="Toggle Dark Mode">
                    <i class="ph ph-moon" id="theme-icon"></i>
                </button>
                <a href="{{ '/ar' | url }}{{ page.url }}" id="lang-toggle" class="text-sm font-bold hover:text-ide-text-strong transition-colors border border-ide-border px-2 py-0.5 rounded" aria-label="Toggle Language Arabic/English">
                    ع
                </a>
                {% if page.url == '/' %}
                <a href="https://www.linkedin.com/in/hussaingaddal/" target="_blank" rel="noopener noreferrer" class="text-2xl hover:text-[#79C0FF] transition-colors hidden md:inline-block" aria-label="LinkedIn Profile">
                    <i class="ph ph-linkedin-logo"></i>
                </a>
                <a href="https://github.com/IronManYG" target="_blank" rel="noopener noreferrer" class="text-2xl hover:text-ide-text-strong transition-colors" aria-label="GitHub Profile">
                    <i class="ph ph-github-logo"></i>
                </a>
                {% endif %}
            </div>
        </div>
    </nav>

    {% if page.url == '/' %}
    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="mobile-menu-overlay">
        <div class="mobile-menu-panel">
            <div class="flex justify-between items-center mb-8">
                <span class="text-xl font-bold font-mono tracking-tighter">
                    <span class="text-kotlin-orange">&lt;</span>HG<span class="text-kotlin-orange">/&gt;</span>
                </span>
                <button id="mobile-menu-close" class="text-2xl text-ide-text-muted hover:text-ide-text-strong transition-colors p-1" aria-label="Close Navigation Menu">
                    <i class="ph ph-x"></i>
                </button>
            </div>
            <div class="flex flex-col space-y-6 text-lg font-medium">
                <a href="#about" class="mobile-nav-link text-ide-text-muted hover:text-ide-text-strong transition-colors">About</a>
                <a href="{{ '/about/' | url }}" class="mobile-nav-link text-ide-text-muted hover:text-ide-text-strong transition-colors">Experience / CV</a>
                <a href="#projects" class="mobile-nav-link text-ide-text-muted hover:text-ide-text-strong transition-colors">Projects</a>
                <a href="#expertise" class="mobile-nav-link text-ide-text-muted hover:text-ide-text-strong transition-colors">Expertise</a>
                <a href="#contact" class="mobile-nav-link text-ide-text-muted hover:text-ide-text-strong transition-colors">Contact</a>
            </div>
            <div class="mt-8 pt-6 border-t border-ide-border flex items-center space-x-6 text-ide-text-muted">
                <a href="https://github.com/IronManYG" target="_blank" rel="noopener noreferrer" class="text-2xl hover:text-ide-text-strong transition-colors" aria-label="GitHub Profile"><i class="ph ph-github-logo"></i></a>
                <a href="https://www.linkedin.com/in/hussaingaddal/" target="_blank" rel="noopener noreferrer" class="text-2xl hover:text-[#79C0FF] transition-colors" aria-label="LinkedIn Profile"><i class="ph ph-linkedin-logo"></i></a>
                <a href="mailto:hussain.yg2010@gmail.com" rel="noopener noreferrer" class="text-2xl hover:text-kotlin-orange transition-colors" aria-label="Email"><i class="ph ph-envelope-simple"></i></a>
            </div>
        </div>
    </div>
    {% endif %}

    <main {% if page.url != '/' %}class="pt-32 pb-24 px-4 sm:px-6 max-w-4xl mx-auto"{% endif %}>
        {{ content | safe }}
    </main>

    {% if page.url == '/' %}
    <!-- Footer / Contact -->
    <footer id="contact" class="py-24 border-t border-ide-border bg-gradient-to-b from-ide-bg to-ide-bg-darker text-center overflow-hidden relative">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-kotlin-purple/10 blur-[120px] rounded-full pointer-events-none"></div>
        <div class="max-w-4xl mx-auto px-4 sm:px-6 fade-section relative z-10">
            <h2 class="text-3xl md:text-5xl font-bold mb-6">Let's build something <span class="gradient-text">extraordinary</span>.</h2>
            <p class="text-ide-text-muted text-lg md:text-xl mb-12 max-w-2xl mx-auto leading-relaxed">
                Looking for a senior engineer to scale your mobile infrastructure or bridge the gap with Cross-Platform solutions? Let's connect.
            </p>
            <div class="flex flex-col md:flex-row justify-center items-center gap-6 mb-12">
                <div class="magnetic-wrap w-full md:w-auto">
                    <a href="mailto:hussain.yg2010@gmail.com" class="btn-primary text-lg px-10 py-5 shadow-kotlin-glow w-full">
                        Say Hello <i class="ph ph-paper-plane-tilt ml-2 text-xl"></i>
                    </a>
                </div>
                <div class="magnetic-wrap w-full md:w-auto">
                    <a href="tel:+966538517374" class="btn-secondary text-lg px-10 py-5 w-full flex items-center justify-center">
                        <i class="ph ph-phone mr-2 text-xl"></i> +966 53 851 7374
                    </a>
                </div>
            </div>
            <div class="flex flex-wrap justify-center items-center gap-8 text-ide-text-muted mb-16">
                <div class="flex items-center gap-2 font-mono text-sm">
                    <i class="ph ph-map-pin text-xl text-kotlin-orange"></i> Riyadh, Saudi Arabia
                </div>
                <div class="h-1 w-1 rounded-full bg-ide-border hidden md:block"></div>
                <div class="flex items-center gap-6">
                    <a href="https://github.com/IronManYG" target="_blank" rel="noopener noreferrer" class="text-3xl hover:text-ide-text-strong transition-all hover:-translate-y-1" aria-label="GitHub Profile">
                        <i class="ph ph-github-logo"></i>
                    </a>
                    <a href="https://www.linkedin.com/in/hussaingaddal/" target="_blank" rel="noopener noreferrer" class="text-3xl hover:text-[#79C0FF] transition-all hover:-translate-y-1" aria-label="LinkedIn Profile">
                        <i class="ph ph-linkedin-logo"></i>
                    </a>
                </div>
            </div>
            <p class="text-sm text-ide-text-dim font-mono border-t border-ide-border/50 pt-12">
                &copy; <span id="copyright-year">2026</span> Hussain Gaddal. <span class="mx-2 text-kotlin-purple font-bold">//</span> Built with Scalability in Mind.
            </p>
        </div>
    </footer>
    {% else %}
    <footer class="py-12 border-t border-ide-border bg-ide-bg text-center text-ide-text-muted text-sm font-mono">
        &copy; 2025-2026 Hussain Gaddal.
    </footer>
    {% endif %}

    <!-- Back to Top Button -->
    <button id="back-to-top" class="fixed bottom-8 right-8 z-40 w-12 h-12 rounded-full bg-kotlin-purple text-white shadow-lg shadow-kotlin-purple/30 flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300 hover:bg-kotlin-orange hover:shadow-kotlin-orange/30 hover:-translate-y-1" aria-label="Back to top">
        <i class="ph ph-arrow-up text-xl"></i>
    </button>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" defer></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" defer></script>
    <script type="module" src="{{ '/js/main.js' | url }}" defer></script>
</body>
</html>
