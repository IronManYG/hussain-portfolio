                    <div class="expertise-card expertise-card-anime p-8 rounded-2xl bg-ide-surface border border-ide-border group hover:border-kotlin-purple/50 transition-all duration-300 lg:col-span-1">
                        <div class="w-12 h-12 rounded-xl bg-kotlin-purple/10 flex items-center justify-center mb-6 group-hover:bg-kotlin-purple/20 transition-colors expertise-icon-anime">
