                        <a href="#projects" class="btn-primary shadow-kotlin-glow mt-0">
                            شاهد أعمالي <i class="ph ph-arrow-left ml-2 text-lg"></i>
                        </a>
                    </div>
                    <div class="magnetic-wrap">
                        <a href="../cv/Hussain_Gaddal_CV.pdf" target="_blank" rel="noopener noreferrer" class="btn-secondary mt-0">
