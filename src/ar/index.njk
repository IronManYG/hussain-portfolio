                    <!-- Data & APIs -->
                    <div class="expertise-card expertise-card-anime p-8 rounded-2xl bg-ide-surface border border-ide-border group hover:border-kotlin-orange/50 transition-all duration-300 lg:col-span-1">
                        <div class="w-12 h-12 rounded-xl bg-kotlin-orange/10 flex items-center justify-center mb-6 group-hover:bg-kotlin-orange/20 transition-colors expertise-icon-anime">
                            <i class="ph ph-database text-2xl text-kotlin-orange"></i>
                        </div>
                        <h4 class="text-xl font-bold mb-3 expertise-title-anime">تدفق البيانات</h4>
                        <p class="text-ide-text-muted text-sm leading-relaxed mb-4 expertise-body-anime">هندسة متينة للبيانات بلا إنترنت (Offline-first) باستخدام Room، <strong class="text-ide-text-strong">Ktor Client</strong>، واجهات GraphQL.</p>
