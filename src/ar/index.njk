        <div class="particles-bg" id="particles-container"></div>
        <div class="relative z-10 grid lg:grid-cols-2 gap-12 items-center">
            <div class="max-w-3xl">
                <div
                    class="inline-flex items-center space-x-2 px-3 py-1 rounded-full border border-ide-border bg-ide-surface text-xs font-mono text-ide-text-muted mb-6 hero-animate hero-badge-anime shadow-sm">
                    <span class="available-dot w-2 h-2 rounded-full bg-green-500"></span>
                    <span>متاح لفرص عمل جديدة</span>
                </div>

                <p class="text-xl md:text-2xl text-ide-text-strong font-semibold mb-2 hero-animate hero-sub-anime">
