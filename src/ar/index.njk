    <!-- About Section -->
    <section id="about" class="py-24 px-4 sm:px-6 border-t border-ide-border bg-gradient-to-b from-ide-bg to-ide-bg-darker overflow-hidden">
        <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 md:gap-16 items-center">
            <div class="fade-section min-w-0">
                <h2 class="text-sm uppercase tracking-widest text-ide-text-muted font-semibold mb-3">نبذة عني</h2>
                <h3 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-6">هندسة متكاملة بين <span class="text-kotlin-purple">الأنظمة</span> و<span class="text-kotlin-orange">تجربة المستخدم</span>.</h3>
                <div class="space-y-4 text-ide-text-muted leading-relaxed break-words overflow-wrap-anywhere">
                    <p>أعمل من الرياض كقائد تطوير تطبيقات أندرويد في شركة <strong>كيه لتقنية المعلومات</strong>. ينصَبُّ تركيزي الشديد على الهيكلة النظيفة (Clean Architecture) والتدفق أحادي الاتجاه للبيانات (MVI/MVVM) وأفضل المعايير العالمية في الاختبارات المؤتمتة.</p>
                    <p>تتمحور أعمالي الحالية حول دفع حدود تطوير الواجهات المتعددة بـ <strong>Compose Multiplatform (CMP)</strong>، بالإضافة إلى تصميم الواجهات الخلفية (Backends) الموثوقة باستخدام <strong>Ktor</strong> لضمان الأداء الفائق والربط الكامل للتقنية.</p>
                    <p>خارج نطاق العمل البرمجي، أستمتع بتعلم تطبيقات الطباعة ثلاثية الأبعاد وصقل مهاراتي التقنية المستمرة.</p>
                </div>
            </div>
            <div class="fade-section code-block-anime relative min-w-0" dir="ltr">
                <!-- Abstract Code Decoration -->
                <div
                    class="absolute -inset-4 bg-gradient-to-tr from-kotlin-purple/20 to-transparent blur-3xl rounded-full pointer-events-none">
                </div>
                <div
                    class="relative bg-ide-surface border border-ide-border rounded-2xl p-3 sm:p-6 font-mono text-[10px] sm:text-sm overflow-hidden shadow-2xl">
                    <div class="flex space-x-2 mb-4">
                        <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
                        <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
                        <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
                    </div>
                    <pre class="text-ide-text-muted overflow-x-auto"><code class="language-kotlin"><span class="text-kotlin-orange">class</span> <span class="text-kotlin-purple">HussainGaddal</span> : <span class="text-ide-text-strong">SeniorAndroidDeveloper</span>() {
    <span class="text-kotlin-orange">val</span> <span class="text-[#79C0FF]">location</span> = <span class="text-[#A5D6FF]">"Riyadh, SA"</span>
    <span class="text-kotlin-orange">val</span> <span class="text-[#79C0FF]">experience</span> = <span class="text-[#A5D6FF]">4</span>

    <span class="text-kotlin-orange">fun</span> <span class="text-[#D2A8FF]">techStack</span>() = listOf(
        <span class="text-[#A5D6FF]">"Kotlin"</span>, 
        <span class="text-[#A5D6FF]">"Jetpack Compose"</span>,
        <span class="text-[#A5D6FF]">"Kotlin Multiplatform"</span>,
        <span class="text-[#A5D6FF]">"Clean Architecture"</span>
    )

    <span class="text-kotlin-orange">fun</span> <span class="text-[#D2A8FF]">buildFeatures</span>() {
        <span class="text-ide-text-muted">/* Deploy robust systems */</span>
    }
}</code></pre>
                </div>
            </div>
        </div>
    </section>

    <!-- Projects (Bento Box Grid) -->
    <section id="projects" class="py-24 px-4 sm:px-6 max-w-7xl mx-auto">
        <div class="flex justify-between items-end mb-12">
            <div>
                <h2 class="text-sm uppercase tracking-widest text-ide-text-muted font-semibold mb-3">أبرز الأعمال</h2>
                <h3 class="text-3xl md:text-4xl font-bold">المشاريع المميزة</h3>
            </div>
            <a href="{{ '/ar/projects/' | url }}" class="hidden sm:inline-flex items-center text-sm font-semibold text-kotlin-purple hover:text-kotlin-purple/80 transition-colors">
                عرض كل المشاريع <i class="ph ph-arrow-left mr-2"></i>
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 auto-rows-[320px] bento-grid-anime">
            {% for project in projects %}
            {% if project.featured %}
            <a href="{{ ('/ar/' + project.slug + '/') | url }}" class="bento-card {{ project.grid.size }} flex flex-col justify-end p-8 group bento-animate {{ project.grid.glow }} glass-noise">
                {% if project.grid.image %}
                <img src="{{ project.grid.image | url }}" alt="{{ project.title_ar }} Hero" class="absolute inset-0 w-full h-full object-cover object-top opacity-40 group-hover:opacity-60 transition-opacity duration-500">
                <div class="absolute inset-0 bg-gradient-to-t from-ide-bg via-ide-bg/80 to-transparent z-10"></div>
                {% elif project.grid.icon %}
                <div class="absolute inset-0 bg-gradient-to-t from-ide-bg to-transparent z-10"></div>
                <i class="ph {{ project.grid.icon }} absolute -left-4 -bottom-4 text-[10rem] {{ project.grid.iconColor }} opacity-[0.03] group-hover:opacity-[0.08] transition-opacity z-0 transform rotate-6"></i>
                <div class="absolute inset-0 bg-ide-surface-hover opacity-40 group-hover:opacity-60 transition-opacity"></div>
                {% endif %}

                <div class="relative z-20 max-w-xl">
                    <div class="flex gap-2 mb-3 max-w-full overflow-hidden flex-wrap">
                        {% for tag in project.tags.slice(0, 3) %}
                        <span class="tech-pill">{{ tag }}</span>
                        {% endfor %}
                    </div>
                    <h4 class="text-2xl font-bold mb-2 group-hover:text-ide-text-strong transition-colors">{{ project.title_ar }}
                        <i class="ph ph-arrow-up-right inline-block opacity-0 group-hover:opacity-100 transition-opacity transform scale-x-[-1]"></i>
                    </h4>
                    <p class="text-ide-text-muted font-light">{{ project.description_ar }}</p>
                </div>
            </a>
            {% endif %}
            {% endfor %}
        </div>
        
        <div class="mt-12 text-center sm:hidden">
            <a href="{{ '/ar/projects/' | url }}" class="inline-flex items-center text-sm font-semibold text-kotlin-purple hover:text-kotlin-purple/80 transition-colors">
                عرض كل المشاريع <i class="ph ph-arrow-left mr-2"></i>
            </a>
        </div>
    </section>

