---
layout: ar_base.njk
title: "نبذة عني | حسين قدال"
description: "الخبرات المهنية، التعليم، والشهادات للمهندس حسين قدال، مطور تطبيقات أندرويد أول."
---

<div class="pt-32 pb-24 px-4 sm:px-6 max-w-7xl mx-auto" dir="rtl">
    <!-- Header -->
    <div class="mb-16 fade-section">
        <h1 class="text-4xl md:text-6xl font-bold mb-6">{{ about_page.ar.hero.title | safe }}</h1>
        <p class="text-xl text-ide-text-muted max-w-3xl leading-relaxed">
            {{ about_page.ar.hero.description | safe }}
        </p>
    </div>

    <!-- Work Experience Section -->
    <section id="experience" class="py-16 border-t border-ide-border">
        <div class="mb-12 fade-section">
            <h2 class="text-3xl font-bold mb-4 font-mono" dir="ltr"><span class="text-kotlin-orange">val</span> <span
                    class="text-ide-text-strong">{{ about_page.ar.experience.section_label }}</span> = <span class="text-[#79C0FF]">{{ about_page.ar.experience.heading_timeline }}</span></h2>
            <p class="text-ide-text-muted text-lg max-w-2xl">{{ about_page.ar.experience.description }}</p>
        </div>

        <div class="relative border-r-2 border-ide-border pr-8 space-y-12 mr-4">
            {% for item in about_page.ar.experience.items %}
            <div class="relative fade-section">
                <!-- Node marker -->
                <div class="absolute -right-[41px] top-1.5 h-4 w-4 rounded-full border-2 ring-4 {{ item.node_color }}">
                </div>

                <div class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-4 mb-2">
                    <h3 class="text-2xl font-bold text-ide-text-strong">{{ item.role }}</h3>
                    <span class="{{ item.color }} font-mono text-sm" dir="ltr">{{ item.company }}</span>
                </div>
                <div class="text-sm text-ide-text-muted font-mono mb-4">{{ item.date_location }}</div>

                <ul class="list-disc pr-5 space-y-3 text-ide-text-muted leading-relaxed">
                    {% for bullet in item.details %}
                    <li>{{ bullet | safe }}</li>
                    {% endfor %}
                </ul>
            </div>
            {% endfor %}
        </div>
    </section>

    <!-- Certifications Section -->
    <section id="certifications" class="py-16 border-t border-ide-border">
        <div class="mb-12 fade-section text-center">
            <h2 class="text-3xl font-bold mb-4 font-mono" dir="ltr"><span class="text-kotlin-orange">import</span>
                <span class="text-[#79C0FF]">{{ about_page.ar.certifications.section_label }}</span></h2>
            <p class="text-ide-text-muted text-lg">{{ about_page.ar.certifications.description }}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 fade-section">
            {% for cert in about_page.ar.certifications.items %}
            <div class="p-6 bg-ide-surface/50 border border-ide-border rounded-xl {{ cert.borderHover }} transition-colors flex items-start gap-4">
                <i class="ph {{ cert.icon }} text-3xl"></i>
                <div>
                    <h4 class="font-bold text-ide-text-strong text-lg">{{ cert.title }}</h4>
                    <p class="text-sm text-ide-text-muted mt-1 leading-relaxed">{{ cert.description | safe }}</p>
                    <p class="text-xs text-ide-text-muted mt-2 font-mono" dir="ltr">{{ cert.provider_year }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </section>

</div>
